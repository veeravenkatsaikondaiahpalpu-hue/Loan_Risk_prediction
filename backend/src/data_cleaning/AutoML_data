import pandas as pd
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parents[3]
DATA_DIR = BASE_DIR / "data" / "processed"

train = pd.read_csv(DATA_DIR / "loan_train.csv")
val = pd.read_csv(DATA_DIR / "loan_val.csv")
test = pd.read_csv(DATA_DIR / "loan_test.csv")

full_df = pd.concat([train, val, test], ignore_index=True)

print("Total rows:", full_df.shape[0])

full_df.to_csv(DATA_DIR / "loan_full_automl.csv", index=False)
